extern int stop_flag;
void stop_car(void)
{
    if(stop_flag == 1)
    {
        gpio_set_level(P11_2, 0);
        gpio_set_level(P11_3, 0);
        GyroP=0;
        GyroI=0;


        pwm_alone=0;
    }
    if(stop_flag == 0)
    {
        gpio_set_level(P11_2, 1);
        gpio_set_level(P11_3, 1);
        GyroP=-80;
        GyroI=-78;


//        pwm_alone=0;
    }
}




