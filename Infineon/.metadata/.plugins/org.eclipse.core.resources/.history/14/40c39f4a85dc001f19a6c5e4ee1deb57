/*
 * motor_value.receive_left_speed_data              左电机转速%d
 * motor_value.receive_right_speed_data             右电机转速%d
 * euler_angle.pitch(理论)                          俯仰角，绕X轴（理论）
 * euler_angle.roll(理论)                           横滚角，绕Y轴（理论）
 * 由于陀螺仪放置问题，现在roll是pitch,原pitch是roll
 * euler_angle.pitch                                横滚角，绕Y轴（实际），直立是0，往4根舵机电源线倒最多-90，往舵机板信号线倒最多+90翻个面为0%f
 * euler_angle.roll                                 俯仰角，绕X轴（实际），直立是180，下载器一边是+180，报警器一边是-180，翻个面是0%f
 * imu660ra_gyro_x                                  x轴角速度，往下载器为正，往报警器为负，直立是0%d
 * imu660ra_gyro_y                                  y轴角速度，往4根舵机电源线为正，往舵机板信号线为负，直立是0%d
 * imu660ra_gyro_z                                  z轴角速度，应该用不到%d
 * */
int core0_main(void)
{
    clock_init();                   // 获取时钟频率<务必保留>
    debug_init();                   // 初始化默认调试串口
    // 此处编写用户代码 例如外设初始化代码等
    imu660ra_init();//陀螺仪初始化,陀螺仪算角速度，卡尔曼滤波后算角度
    EKF_Init();//卡尔曼初始化
    small_driver_uart_init();//无刷驱动 参数初始化，给速度
    /* PID *pid                  pid结构体                      pid0_stand.inner站立pid的内环（角速度环）
     * float p                  比例项参数
     * float i                  积分项参数
     * float d                  微分项参数
     * float maxI               积分项限幅
     * float maxOut             输出限幅
     * */
    PID_Init(&pid0_stand.inner,0,0,0,0,8000);//初始化站立，内环pid参数
    PID_Clear(&pid0_stand.inner);//清空站立，内环pid的历史数据
    mode=0;//初始模式为0，站立

    pit_ms_init(CCU60_CH1,5);//中断设置初始化

    // 此处编写用户代码 例如外设初始化代码等
    cpu_wait_event_ready();         // 等待所有核心初始化完毕
    while (TRUE)
    {
        // 此处编写需要循环执行的代码
        EKF_UpData();//卡尔曼滤波更新姿态
        // 此处编写需要循环执行的代码
    }
}

#pragma section all restore
