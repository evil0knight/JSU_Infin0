//初始化pid参数
void PID_Init(PID *pid,float p,float i,float d,float maxI,float maxOut)
{
	pid->kp=p;
	pid->ki=i;
	pid->kd=d;
	pid->maxIntegral=maxI;
	pid->maxOutput=maxOut;
	pid->deadzone=0;
	pid->errLpfRatio=0;
}
void PID_Init_inner(CascadePID *pid,float p,float i,float d,float maxI,float maxOut)//内环参数初始化
{
    PID_Init(&pid->inner_left,p,i,d,maxI,maxOut);
    PID_Init(&pid->inner_right,p,i,d,maxI,maxOut);
}
void PID_Init_middler(CascadePID *pid,float p,float i,float d,float maxI,float maxOut)//中环参数初始化
{
    PID_Init(&pid->middler_left,p,i,d,maxI,maxOut);
    PID_Init(&pid->middler_right,p,i,d,maxI,maxOut);
}
/*单级pid计算，位置式
 * reference                    参考，目标
 * feedback                     反馈，现状
 */
void PID_SingleCalc(PID *pid,float reference,float feedback)
{
	//更新数据
	pid->lastError=pid->error;
	if(ABS(reference-feedback) < pid->deadzone)//若误差在死区内则error直接置0
		pid->error=0;
	else
		pid->error=reference-feedback;
	//低通滤波
	pid->error=pid->error*pid->errLpfRatio+pid->lastError*(1-pid->errLpfRatio);
	//计算微分
	pid->output=(pid->error-pid->lastError)*pid->kd;
	//计算比例
	pid->output+=pid->error*pid->kp;
	//计算积分
	pid->integral+=pid->error*pid->ki;
	LIMIT(pid->integral,-pid->maxIntegral,pid->maxIntegral);//积分限幅
	pid->output+=pid->integral;
	//输出限幅
	LIMIT(pid->output,-pid->maxOutput,pid->maxOutput);
}

